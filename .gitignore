# --- build outputs (regenerated by `make`) ---
# /build/ holds the vendored engine archives + objects (build/lib, build/obj)
/build/
# staged copies of engines/{js,python}/ sources + the assembled deployable site (make dist)
/web/js/
/web/python/
/dist/
